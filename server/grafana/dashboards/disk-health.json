{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "DiskHealth — Fleet Overview",
  "tags": ["diskhealth"],
  "time": { "from": "now-90d", "to": "now" },
  "timezone": "",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "table",
      "title": "Latest SMART status (per disk)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "diskhealth" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FAIL", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "PASS", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "showHeader": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "diskhealth" },
          "query": "from(bucket: \"smart\")\n  |> range(start: -30d)\n  |> filter(fn: (r) => r._measurement == \"disk_smart\" and r._field == \"smart_passed\")\n  |> group(columns: [\"device_id\", \"host\", \"model\", \"serial\"])\n  |> last()\n  |> keep(columns: [\"device_id\", \"host\", \"model\", \"serial\", \"_value\"])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Reallocated sectors (ATA #5, raw)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "influxdb", "uid": "diskhealth" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "showPoints": "always" } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "diskhealth" },
          "query": "from(bucket: \"smart\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"disk_smart\" and r._field == \"reallocated_sector_ct\")\n  |> group(columns: [\"device_id\", \"serial\"])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Current pending sectors (ATA #197, raw)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "influxdb", "uid": "diskhealth" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "showPoints": "always" } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "diskhealth" },
          "query": "from(bucket: \"smart\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"disk_smart\" and r._field == \"current_pending_sector\")\n  |> group(columns: [\"device_id\", \"serial\"])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "NVMe wear — percentage used (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "datasource": { "type": "influxdb", "uid": "diskhealth" },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "custom": { "drawStyle": "line" } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "diskhealth" },
          "query": "from(bucket: \"smart\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"disk_smart\" and r._field == \"nvme_percentage_used\")\n  |> group(columns: [\"device_id\", \"serial\"])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Temperature (°C)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "datasource": { "type": "influxdb", "uid": "diskhealth" },
      "fieldConfig": { "defaults": { "unit": "celsius", "custom": { "drawStyle": "line" } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "diskhealth" },
          "query": "from(bucket: \"smart\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"disk_smart\" and r._field == \"temperature_c\")\n  |> group(columns: [\"device_id\", \"serial\"])"
        }
      ]
    }
  ]
}
