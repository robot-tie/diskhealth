# Copy to .env and fill in. Keep .env out of git (see .gitignore).

# Public domain that points (A record) at this VPS's static IP.
DOMAIN=disk-health.example.com
# Email for Let's Encrypt expiry notices.
ACME_EMAIL=you@example.com

# InfluxDB initial setup
INFLUX_USERNAME=admin
INFLUX_PASSWORD=change-me-strong-password
INFLUX_ORG=diskhealth
INFLUX_BUCKET=smart
# How long to keep raw points. 0s = forever. e.g. 520w ~= 10 years.
INFLUX_RETENTION=0s
# Admin/API token shared by the ingest service and Grafana datasource.
# Generate with:  openssl rand -hex 32
INFLUX_TOKEN=change-me-influx-admin-token

# Grafana admin login (the web UI you'll log into)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
